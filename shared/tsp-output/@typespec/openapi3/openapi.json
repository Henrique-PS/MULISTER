{
  "openapi": "3.0.0",
  "info": {
    "title": "Mulister API",
    "version": "0.0.0"
  },
  "tags": [
    {
      "name": "Playlist Transfer"
    }
  ],
  "paths": {
    "/transfer": {
      "post": {
        "operationId": "PlaylistTransfer_transfer",
        "summary": "Transfer playlists from one audio streaming service to another",
        "parameters": [],
        "responses": {
          "204": {
            "description": "There is no content to send for this request, but the headers may be useful. "
          },
          "400": {
            "description": "The server could not understand the request due to invalid syntax."
          }
        },
        "tags": [
          "Playlist Transfer"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "playlists": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Playlist"
                    }
                  },
                  "target_streaming": {
                    "$ref": "#/components/schemas/Streaming"
                  }
                },
                "required": [
                  "playlists",
                  "target_streaming"
                ]
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Playlist": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier for the playlist"
          },
          "name": {
            "type": "string",
            "description": "The name of the playlist"
          },
          "description": {
            "type": "string",
            "description": "The description of the playlist"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Track"
            },
            "description": "The list of tracks in the playlist"
          }
        }
      },
      "Streaming": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier for the streaming service"
          },
          "name": {
            "type": "string",
            "description": "The name of the streaming service"
          },
          "url": {
            "type": "string",
            "description": "The URL of the streaming service"
          }
        }
      },
      "Track": {
        "type": "object",
        "required": [
          "id",
          "isrc",
          "name",
          "artists"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier for the track"
          },
          "isrc": {
            "type": "string",
            "description": "The International Standard Recording Code for the track"
          },
          "name": {
            "type": "string",
            "description": "The name of the track"
          },
          "artists": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The list of artists for the track"
          }
        }
      }
    }
  }
}
