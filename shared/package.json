{
  "name": "@mulister/shared",
  "version": "1.0.0",
  "description": "Shared contracts and typings for the project",
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "build": "tsp compile main.tsp && openapi-typescript ./tsp-output/@typespec/openapi3/openapi.json -o ./types.ts"
